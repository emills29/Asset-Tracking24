// SERVER SETTINGS 

# Port your backend runs on
# Your website will connect to: http://localhost:3000
PORT=3000


// CISCO SPACES SETTINGS 

# Base URL for Cisco Spaces API (depends on region)
# US = dnaspaces.io
# EU = dnaspaces.eu
# Asia = ciscospaces.sg
CISCO_SPACES_BASE_URL=https://dnaspaces.io


# Your Cisco Spaces API token (KEEP THIS PRIVATE)
# Used to authenticate requests to get device locations
CISCO_SPACES_TOKEN=


// TRACKER SETTINGS 

# How long (in seconds) before a tracker is considered "offline"
# If ESP32 hasn't sent data in this time → mark as inactive
HEARTBEAT_STALE_SECONDS=45
